FROM registry.access.redhat.com/ubi9/python-311:latest

COPY server.py /opt/app-root/src/server.py

RUN pip install --no-cache-dir flask opencv-python-headless

# Videos are mounted at runtime via PVC or ConfigMap, not baked in.
# Place .mp4 files in /data/videos/ (named per camera, e.g. overhead.mp4)
# Or pre-extracted JPEGs in /data/frames/{camera_name}/*.jpg

EXPOSE 8211

CMD ["python", "/opt/app-root/src/server.py"]
