# Copy to .env and fill in your values:
#   cp .env.example .env

REGISTRY=quay.io/jary
IMAGE_TAG=latest
CENTRAL_NS=ai-showcase-central
MLOPS_NS=ai-showcase-mlops
FACTORY_SITES=ai-showcase-factory-a ai-showcase-factory-b
ISAAC_SIM_IMAGE=nvcr.io/nvidia/isaac-sim:5.1.0
VLLM_IMAGE=vllm/vllm-openai:latest
MOSQUITTO_IMAGE=docker.io/library/eclipse-mosquitto:2
COSMOS_MODEL=nvidia/Cosmos-Reason2-2B

# NGC API key — required for all charts.
# Used for: pulling images from nvcr.io, downloading NGC resources (camera videos),
# and authenticating TAO training jobs.
NGC_API_KEY=

# HuggingFace token — required for factory charts.
# Used for downloading gated models (e.g. nvidia/Cosmos-Reason2-2B for edge inference).
# Accept the model license first: https://huggingface.co/nvidia/Cosmos-Reason2-2B
HF_TOKEN=

# MinIO object storage credentials (MLOps chart)
MINIO_PASSWORD=<generate-a-strong-password>

# Model Registry Postgres credentials (MLOps chart)
REGISTRY_DB_PASSWORD=<generate-a-strong-password>
