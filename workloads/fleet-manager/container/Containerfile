# This project was developed with assistance from AI tools.
# Build from repo root: podman build -f workloads/fleet-manager/container/Containerfile -t fleet-manager:dev .
FROM registry.access.redhat.com/ubi9/python-312:latest

USER 0
RUN dnf install -y --setopt=install_weak_deps=False \
        librdkafka \
    && dnf clean all && rm -rf /var/cache/dnf

ENV PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /opt/app-root/src

# Install shared lib first (layer caching).
COPY workloads/common/python-lib /opt/app-root/src/common-lib
RUN pip install /opt/app-root/src/common-lib

# Install this service.
COPY workloads/fleet-manager/pyproject.toml /opt/app-root/src/fleet-manager/
COPY workloads/fleet-manager/src /opt/app-root/src/fleet-manager/src
RUN pip install /opt/app-root/src/fleet-manager

USER 1001
EXPOSE 8080
CMD ["uvicorn", "fleet_manager.main:app", "--host", "0.0.0.0", "--port", "8080"]
