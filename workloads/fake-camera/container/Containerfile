# This project was developed with assistance from AI tools.
FROM registry.access.redhat.com/ubi9/python-312:latest

USER 0
RUN dnf install -y --setopt=install_weak_deps=False \
        librdkafka \
    && dnf clean all && rm -rf /var/cache/dnf

ENV PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /opt/app-root/src

COPY workloads/common/python-lib /opt/app-root/src/common-lib
RUN pip install /opt/app-root/src/common-lib

COPY workloads/fake-camera/pyproject.toml /opt/app-root/src/fake-camera/
COPY workloads/fake-camera/src /opt/app-root/src/fake-camera/src
RUN pip install /opt/app-root/src/fake-camera

# Bake the Phase-1 frame library into the image. Source-of-truth JPEGs live
# under workloads/obstruction-detector/test-images/ (also uploaded to the
# hub MinIO warehouse-camera-library bucket). Keeping a copy in the image
# means the companion doesn't need to reach hub-side object storage to serve
# frames — the camera is self-sufficient.
COPY workloads/obstruction-detector/test-images/aisle3_empty.jpg /frames/aisle3_empty.jpg
COPY workloads/obstruction-detector/test-images/aisle3_pallet.jpg /frames/aisle3_pallet.jpg

USER 1001
EXPOSE 8085
CMD ["uvicorn", "fake_camera.main:app", "--host", "0.0.0.0", "--port", "8085"]
